@model Clinic.Models.Patient

@{
    ViewData["Title"] = "Confirm Patient Deletion";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white text-center py-4">
                    <i class="fas fa-user-times fa-3x mb-3"></i>
                    <h2 class="mb-0">Delete Patient?</h2>
                    <p class="mb-0 mt-2 opacity-75">Caution: This action will permanently remove the patient record.</p>
                </div>

                <div class="card-body p-4 p-lg-5 text-center">
                    <h5 class="text-muted mb-4">Are you sure you want to delete this patient?</h5>

                    <div class="bg-light p-4 rounded-3 mb-4 shadow-sm border-start border-danger border-4">
                        <div class="row align-items-center mb-3">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold text-start">
                                <i class="fas fa-id-card me-1"></i> Patient Name
                            </div>
                            <div class="col-sm-8 h5 mb-0 text-start">
                                <strong>@Html.DisplayFor(model => model.Name)</strong>
                            </div>
                        </div>
                        <div class="row align-items-center">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold text-start">
                                <i class="fas fa-birthday-cake me-1"></i> Age
                            </div>
                            <div class="col-sm-8 h5 mb-0 text-start">
                                <span class="badge bg-secondary">@Html.DisplayFor(model => model.Age) Years Old</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                                <i class="fas fa-trash-alt me-2"></i> Confirm Delete
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                                <i class="fas fa-times me-1"></i> Keep Record
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-white text-center py-3 border-top-0">
                    <small class="text-muted italic">
                        <i class="fas fa-shield-alt me-1"></i> Data Protection Protocol Active
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}