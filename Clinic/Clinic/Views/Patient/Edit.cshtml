@model Clinic.Models.Patient

@{
    ViewData["Title"] = "Edit Patient";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0"><i class="fas fa-user-edit me-2"></i> Update Patient Info</h3>
                    <p class="mb-0 mt-1 opacity-75">Modifying record for ID: #@Model.Id</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control border-0 bg-light shadow-sm" placeholder="Full Name" />
                            <label asp-for="Name"><i class="fas fa-id-card me-1 text-muted"></i> Patient Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Age" type="number" class="form-control border-0 bg-light shadow-sm" placeholder="Age" />
                            <label asp-for="Age"><i class="fas fa-calendar-alt me-1 text-muted"></i> Age</label>
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>

                        <div class="row g-2">
                            <div class="col-8">
                                <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                    <i class="fas fa-save me-1"></i> Save Changes
                                </button>
                            </div>
                            <div class="col-4">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 shadow-sm">
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-muted small">
                        <i class="fas fa-eye me-1"></i> View current profile details
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}