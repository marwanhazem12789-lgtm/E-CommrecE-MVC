@model Clinic.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white py-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-0"><i class="fas fa-calendar-check me-2 text-info"></i> Appointment Info</h3>
                            <small class="text-light opacity-75">Booking Reference: #@Model.Id</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-info text-dark p-2 px-3">
                                <i class="fas fa-clock me-1"></i> Scheduled
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-user-injured me-1"></i> Patient</label>
                            <h4 class="text-primary mt-1">@Html.DisplayFor(model => model.Patient.Name)</h4>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-user-md me-1"></i> Assigned Doctor</label>
                            <h4 class="text-dark mt-1">Dr. @Html.DisplayFor(model => model.Doctor.Name)</h4>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-4 py-3 bg-light rounded-3 mx-1">
                        <div class="col-sm-6 text-center border-end">
                            <label class="d-block text-muted small fw-bold">DATE</label>
                            <span class="h5">@Model.Date.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="col-sm-6 text-center">
                            <label class="d-block text-muted small fw-bold">TIME</label>
                            <span class="h5">@Model.Date.ToString("hh:mm tt")</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-sticky-note me-1"></i> Medical Notes</label>
                        <div class="p-3 border rounded-3 mt-1 bg-white shadow-sm italic">
                            @(string.IsNullOrEmpty(Model.Notes) ? "No special instructions provided." : Model.Notes)
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 d-flex justify-content-between p-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm">
                        <i class="fas fa-arrow-left me-1"></i> Back to Schedule
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4 shadow-sm">
                        <i class="fas fa-edit me-1"></i> Reschedule / Edit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}