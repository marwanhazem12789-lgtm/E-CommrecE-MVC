@model Clinic.Models.Doctor

@{
    ViewData["Title"] = "Confirm Deletion";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-danger text-white text-center py-4">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                    <h2 class="mb-0">Are you sure?</h2>
                    <p class="mb-0 mt-2 opacity-75">This action cannot be undone. All records for this doctor will be removed.</p>
                </div>

                <div class="card-body p-4 text-center">
                    <h4 class="text-muted mb-4">You are about to delete the following doctor:</h4>

                    <div class="bg-light p-4 rounded-3 mb-4">
                        <div class="row align-items-center">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">
                                <i class="fas fa-user-md me-1"></i> Doctor Name
                            </div>
                            <div class="col-sm-8 h5 mb-0">
                                <strong>@Html.DisplayFor(model => model.Name)</strong>
                            </div>
                        </div>
                        <hr />
                        <div class="row align-items-center">
                            <div class="col-sm-4 text-muted small text-uppercase fw-bold">
                                <i class="fas fa-stethoscope me-1"></i> Specialty
                            </div>
                            <div class="col-sm-8 h5 mb-0 text-danger">
                                @Html.DisplayFor(model => model.Specialiy)
                            </div>
                        </div>
                    </div>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2 d-md-block">
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                                <i class="fas fa-trash-alt me-1"></i> Yes, Delete Doctor
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                                <i class="fas fa-times me-1"></i> No, Keep Record
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-2 border-0">
                    <small class="text-muted italic">Clinic Management System - Security Protocol</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}