@model Clinic.Models.Doctor

@{
    ViewData["Title"] = "Update Doctor Information";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0"><i class="fas fa-user-edit me-2"></i> Edit Doctor Details</h3>
                    <small>Updating information for: <strong>@Model.Name</strong></small>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control border-0 bg-light shadow-sm" placeholder="Doctor Name" />
                            <label asp-for="Name"><i class="fas fa-id-card me-1 text-muted"></i> Full Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Specialiy" class="form-control border-0 bg-light shadow-sm" placeholder="Specialty" />
                            <label asp-for="Specialiy"><i class="fas fa-stethoscope me-1 text-muted"></i> Specialty</label>
                            <span asp-validation-for="Specialiy" class="text-danger small"></span>
                        </div>

                        <div class="row g-2">
                            <div class="col-8">
                                <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                    <i class="fas fa-check-circle me-1"></i> Save Changes
                                </button>
                            </div>
                            <div class="col-4">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 shadow-sm">
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-3 border-0">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none small text-muted">
                        <i class="fas fa-eye me-1"></i> View Profile Preview
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}