@model Clinic.Models.Doctor

@{
    ViewData["Title"] = "Doctor Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <i class="fas fa-user-md fa-4x mb-3"></i>
                    <h2 class="mb-0">Doctor Profile</h2>
                </div>

                <div class="card-body p-5">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">
                            <i class="fas fa-id-badge me-2"></i> @Html.DisplayNameFor(model => model.Name)
                        </div>
                        <div class="col-sm-8 text-dark h5">
                            <strong>@Html.DisplayFor(model => model.Name)</strong>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">
                            <i class="fas fa-stethoscope me-2"></i> @Html.DisplayNameFor(model => model.Specialiy)
                        </div>
                        <div class="col-sm-8">
                            <span class="badge bg-info text-dark p-2 px-3 h6">
                                @Html.DisplayFor(model => model.Specialiy)
                            </span>
                        </div>
                    </div>

                    <hr />

                    <div class="alert alert-light border-start border-primary border-4 mt-4">
                        <small class="text-muted italic">
                            <i class="fas fa-info-circle me-1"></i>
                            This doctor is registered in the Clinic Management System.
                        </small>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between p-3">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4">
                        <i class="fas fa-user-edit"></i> Edit Info
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
}