@model E_CommrecE_MVC.Models.OrderCustomer

@{
    ViewData["Title"] = "Create Order";
}

<h1>Create Order</h1>

<hr />
<div class="row">
    <div class="col-md-10">
        @* كبرنا المساحة شوية عشان الجدول *@
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* 1. اختيار العميل *@
            <div class="form-group mb-4">
                <label class="control-label">Select Customer</label>
                <select asp-for="selectedCustomerId" class="form-control"
                        asp-items="@(new SelectList(Model.Customers, "Id", "Name"))">
                    <option value="">-- Choose Customer --</option>
                </select>
                <span asp-validation-for="selectedCustomerId" class="text-danger"></span>
            </div>

            @* 2. جدول المنتجات *@
            <h4>Products List</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Price</th>
                        <th>Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.OrderProducts.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model.OrderProducts[i].Name
                                @* مهم جداً: الـ Hidden Fields دي اللي بترجع البيانات للـ Controller *@
                                <input type="hidden" asp-for="OrderProducts[i].ProductId" />
                                <input type="hidden" asp-for="OrderProducts[i].Name" />
                                <input type="hidden" asp-for="OrderProducts[i].Price" />
                            </td>
                            <td>@Model.OrderProducts[i].Price</td>
                            <td>
                                <input asp-for="OrderProducts[i].Quantity" class="form-control" type="number" value="0" min="0" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="form-group mt-3">
                <input type="submit" value="Place Order" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}